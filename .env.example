# API Keys for AI providers
# Copy this file to .env.local and replace the placeholders with your actual API keys

# OpenAI API key - Get from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Anthropic API key - Get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Groq API key - Get from https://console.groq.com/keys
GROQ_API_KEY=

# Mistral API key - Get from https://console.mistral.ai/
# MISTRAL_API_KEY=

# DeepSeek API key
# DEEPSEEK_API_KEY=

# To use the simulation mode, set any of the above to "USE_SIMULATION"
# Example: OPENAI_API_KEY=USE_SIMULATION 